        <mxCell id="BlRtzGTYbiUgU63JzdBe-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="SSE" vertex="1">
          <mxGeometry height="30" width="60" x="270" y="420" as="geometry" />
        </mxCell>
        <mxCell id="BlRtzGTYbiUgU63JzdBe-20" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;ul&gt;&lt;li&gt;User can create auction using action service&lt;/li&gt;&lt;li&gt;Update bid service using transaction and locks to deal with consistency. As people would be reading existing bid and then add new bid for that auction. if 2 person try to read and update then this can cause inconsistency.&lt;/li&gt;&lt;ul&gt;&lt;li&gt;we apply lock on single record in auction table instead of putting lock on whole bid table.&lt;/li&gt;&lt;/ul&gt;&lt;li&gt;Client request for bid update, it goes to kafka, update in db and the send the event to client&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&amp;nbsp;Here suppose kafka push event to bid service 2 but bid service 1 is connected to client1, So to handle this we use pub/sub again where bidservice publish event whenever it gets the event and other instances consumes it. bid service who is connected to client1 consumes it and send to client1&lt;/li&gt;&lt;li&gt;Note each bid service store the client info in-memory to whom it is connected.&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="30" width="560" x="70" y="540" as="geometry" />
        </mxCell>
        <mxCell id="BlRtzGTYbiUgU63JzdBe-25" edge="1" parent="1" source="BlRtzGTYbiUgU63JzdBe-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;exitPerimeter=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" target="BlRtzGTYbiUgU63JzdBe-21">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="BlRtzGTYbiUgU63JzdBe-23" parent="1" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.managed_streaming_for_kafka;" value="" vertex="1">
